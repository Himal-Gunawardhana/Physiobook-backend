# ============================================================
#  PHYSIOBOOK v1 - ENVIRONMENT CONFIGURATION TEMPLATE
#  Copy this file to .env and fill in all placeholder values
# ============================================================

# ── App ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_VERSION=v1

# ── CORS (comma-separated list of allowed origins) ───────────
CORS_ORIGINS=http://localhost:3000,https://app.physiobook.com

# ── JWT ──────────────────────────────────────────────────────
JWT_ACCESS_SECRET=REPLACE_WITH_STRONG_RANDOM_SECRET_MIN_64_CHARS
JWT_REFRESH_SECRET=REPLACE_WITH_ANOTHER_STRONG_RANDOM_SECRET_MIN_64_CHARS
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── PostgreSQL (AWS RDS / self-hosted) ───────────────────────
DB_HOST=REPLACE_WITH_DB_HOST          # e.g. my-db.xxxxxxxx.us-east-1.rds.amazonaws.com
DB_PORT=5432
DB_NAME=physiobook
DB_USER=REPLACE_WITH_DB_USERNAME
DB_PASSWORD=REPLACE_WITH_DB_PASSWORD
DB_SSL=true                           # set to false for local dev without SSL
DB_POOL_MIN=2
DB_POOL_MAX=10

# ── Redis (AWS ElastiCache / Upstash / self-hosted) ──────────
REDIS_HOST=REPLACE_WITH_REDIS_HOST   # e.g. my-redis.xxxxxx.0001.use1.cache.amazonaws.com
REDIS_PORT=6379
REDIS_PASSWORD=REPLACE_WITH_REDIS_PASSWORD
REDIS_TLS=false                       # set to true for ElastiCache / Upstash

# ── Stripe Payments ──────────────────────────────────────────
STRIPE_SECRET_KEY=REPLACE_WITH_STRIPE_SECRET_KEY         # sk_live_... or sk_test_...
STRIPE_PUBLISHABLE_KEY=REPLACE_WITH_STRIPE_PUBLISHABLE_KEY
STRIPE_WEBHOOK_SECRET=REPLACE_WITH_STRIPE_WEBHOOK_SECRET # whsec_...
STRIPE_CURRENCY=LKR

# ── Email (AWS SES / SendGrid / SMTP) ────────────────────────
EMAIL_PROVIDER=smtp                   # options: smtp | ses | sendgrid
SMTP_HOST=REPLACE_WITH_SMTP_HOST     # e.g. email-smtp.us-east-1.amazonaws.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=REPLACE_WITH_SMTP_USERNAME
SMTP_PASS=REPLACE_WITH_SMTP_PASSWORD
EMAIL_FROM_ADDRESS=no-reply@physiobook.com
EMAIL_FROM_NAME=Physiobook

# ── AWS SES (only if EMAIL_PROVIDER=ses) ─────────────────────
AWS_SES_REGION=us-east-1
AWS_ACCESS_KEY_ID=REPLACE_WITH_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=REPLACE_WITH_AWS_SECRET_ACCESS_KEY

# ── SendGrid (only if EMAIL_PROVIDER=sendgrid) ───────────────
SENDGRID_API_KEY=REPLACE_WITH_SENDGRID_API_KEY

# ── SMS / OTP (Twilio) ───────────────────────────────────────
TWILIO_ACCOUNT_SID=REPLACE_WITH_TWILIO_ACCOUNT_SID
TWILIO_AUTH_TOKEN=REPLACE_WITH_TWILIO_AUTH_TOKEN
TWILIO_PHONE_NUMBER=REPLACE_WITH_TWILIO_PHONE_NUMBER

# ── File Storage (AWS S3) ─────────────────────────────────────
AWS_S3_BUCKET=REPLACE_WITH_S3_BUCKET_NAME
AWS_S3_REGION=us-east-1
AWS_S3_ACCESS_KEY_ID=REPLACE_WITH_S3_ACCESS_KEY_ID
AWS_S3_SECRET_ACCESS_KEY=REPLACE_WITH_S3_SECRET_ACCESS_KEY

# ── 2FA / TOTP ────────────────────────────────────────────────
TOTP_APP_NAME=Physiobook

# ── Rate Limiting ─────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000           # 15 minutes
RATE_LIMIT_MAX_REQUESTS=100
AUTH_RATE_LIMIT_MAX=10                # stricter limit for auth endpoints

# ── Logging ───────────────────────────────────────────────────
LOG_LEVEL=info                        # error | warn | info | debug

# ── Frontend URL (for email links / redirects) ────────────────
FRONTEND_URL=https://app.physiobook.com
