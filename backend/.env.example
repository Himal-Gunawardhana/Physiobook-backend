# ─── Core ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
API_VERSION=v1
FRONTEND_URL=https://physiobook.vercel.app

# ─── Database (PostgreSQL) ────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/physiobook

# ─── Cache / Sessions (Redis) ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT — RS256 (base64 encoded) ────────────────────────────────────────────
# Generate with:
#   openssl genrsa -out private.pem 2048
#   openssl rsa -in private.pem -pubout -out public.pem
#   cat private.pem | base64 -w 0  → paste as JWT_PRIVATE_KEY
#   cat public.pem  | base64 -w 0  → paste as JWT_PUBLIC_KEY
# Or leave both empty to use HS256 with JWT_SECRET (dev only)
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_SECRET=change-me-in-production-minimum-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# ─── Email (SendGrid) ─────────────────────────────────────────────────────────
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=no-reply@physiobook.com

# ─── SMS (Twilio) ─────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_FROM_NUMBER=+1xxxxxxxxxx

# ─── Payments (Stripe) ────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── File Storage (AWS S3 or Cloudflare R2) ───────────────────────────────────
AWS_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_S3_BUCKET=physiobook-assets
AWS_REGION=ap-south-1
# Cloudflare R2: set AWS_ENDPOINT to your R2 account endpoint
# AWS_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=https://physiobook.vercel.app,http://localhost:5173,http://localhost:3000
